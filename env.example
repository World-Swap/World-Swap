# Copy to .env for local dev (Render uses dashboard env vars).
DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require
TEST_MODE=true
ASSET_ENCRYPTION_KEY=change-me-to-32-plus-random-chars
SESSION_SECRET=change-me-to-32-plus-random-chars   # signs sign-in cookies
PORT=8080

# On-chain (only when TEST_MODE=false)
CHAIN_NAME=base-sepolia
RPC_URL=
USDC_ADDRESS=
ESCROW_ADDRESS=
FEE_RECIPIENT=
ARBITER_ADDRESS=
CONFIRMATIONS=2
