{
  "name": "world-swap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "start": "node server/index.js",
    "watcher": "node server/escrowWatcher.js",
    "migrate": "node -e \"import('pg').then(async({default:pg})=>{const c=new pg.Client({connectionString:process.env.DATABASE_URL,ssl:{rejectUnauthorized:false}});await c.connect();await c.query((await import('node:fs')).readFileSync('db/schema.sql','utf8'));await c.end();console.log('migrated')})\"",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "ethers": "^6.13.0"
  }
}
